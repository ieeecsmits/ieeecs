# ---- Server ----
PORT=5000
NODE_ENV=development
# Set to "true" when running behind a reverse proxy (nginx, render, fly, etc.)
# so express-rate-limit sees the real client IP from X-Forwarded-For.
TRUST_PROXY=false

# ---- CORS ----
# Comma-separated list of allowed origins.
FRONTEND_URL=http://localhost:5173

# ---- Database (MongoDB) ----
# Local:   mongodb://127.0.0.1:27017/ieee_cs
# Atlas:   mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/ieee_cs?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/ieee_cs
# Auto-create indexes on startup (off in production — run `npm run db:sync-indexes` explicitly).
MONGOOSE_AUTO_INDEX=true

# ---- Auth (JWT) ----
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
# bcrypt cost factor (10–14). Higher = slower & safer.
BCRYPT_ROUNDS=12

# ---- Seed script (only required when running `npm run db:seed`) ----
SEED_ADMIN_NAME=IEEE CS Admin
SEED_ADMIN_EMAIL=admin@ieeecs.ac.in
# Must be at least 12 characters.
SEED_ADMIN_PASSWORD=
