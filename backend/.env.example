# ---- Server ----
PORT=5000
NODE_ENV=development
# Set to "true" only when running behind a reverse proxy (nginx, render, fly, etc.)
# so express-rate-limit sees the real client IP from X-Forwarded-For.
TRUST_PROXY=false

# ---- CORS ----
# Comma-separated list of allowed origins.
FRONTEND_URL=http://localhost:5173

# ---- Database (PostgreSQL) ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ieee_cs
# Max connections in the pg pool (defaults to 10).
PG_POOL_MAX=10

# ---- Auth (JWT) ----
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
# bcrypt cost factor (10–14). Higher = slower & safer.
BCRYPT_ROUNDS=12

# ---- Seed script (only required when running `npm run db:seed`) ----
SEED_ADMIN_NAME=IEEE CS Admin
SEED_ADMIN_EMAIL=admin@ieeecs.ac.in
# Must be at least 12 characters.
SEED_ADMIN_PASSWORD=
